{
  "name": "folder-forge",
  "version": "1.0.0",
  "description": "Create reusable folder structures for your projects",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build": "electron-builder --mac --win"
  },
  "keywords": ["folder", "template", "productivity", "motion-design"],
  "author": "Harish",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.folderforge.app",
    "productName": "Folder Forge",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "target": ["dmg"]
    },
    "win": {
      "icon": "assets/icon.png",
      "target": ["nsis"]
    },
    "files": [
      "src/**/*"
    ],
    "asarUnpack": [
      "assets/**/*"
    ]
  }
}
